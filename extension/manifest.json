{
  "manifest_version": 3,
  "name": "PolyParlay — Parlay Builder for Polymarket",
  "version": "0.1.0",
  "description": "Build multi-leg parlays from Polymarket markets. See combined multiplier and max payout. Generate shareable slip cards. Information only — no execution.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://gamma-api.polymarket.com/*",
    "https://polymarket.com/*",
    "https://*.polymarket.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PolyParlay"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/*", "https://*.polymarket.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
