{
  "manifest_version": 3,
  "name": "PolyParlay — Parlay Builder for Polymarket",
  "version": "1.0.43",
  "description": "Build multi-leg parlays from Polymarket. 10K Monte Carlo, auto-rebalance weak legs, shareable slip cards.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://gamma-api.polymarket.com/*",
    "https://data-api.polymarket.com/*",
    "https://polymarket.com/*",
    "https://*.polymarket.com/*",
    "https://*.workers.dev/*",
    "https://polyparlay.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PolyParlay",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/*", "https://*.polymarket.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["https://polyparlay.app/*", "https://*.polyparlay.app/*"]
  }
}
