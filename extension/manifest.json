{
  "manifest_version": 3,
  "name": "PolyParlay — Parlay Builder for Polymarket",
  "version": "1.0.3",
  "description": "Build multi-leg parlays from Polymarket markets. Run 10K Monte Carlo simulations, auto-rebalance weak legs, share viral slip cards. Information only — no execution.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://gamma-api.polymarket.com/*",
    "https://data-api.polymarket.com/*",
    "https://polymarket.com/*",
    "https://*.polymarket.com/*",
    "https://*.workers.dev/*",
    "https://polyparlay.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PolyParlay"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://polymarket.com/*", "https://*.polymarket.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["https://polyparlay.io/*", "https://*.polyparlay.io/*"]
  }
}
